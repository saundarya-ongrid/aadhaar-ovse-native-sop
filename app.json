{
   "expo": {
      "name": "aadhaar-ovse-sop",
      "slug": "aadhaar-ovse-sop",
      "version": "1.0.0",
      "orientation": "portrait",
      "icon": "./assets/images/icon.png",
      "scheme": "aadhaarovsesop",
      "userInterfaceStyle": "automatic",
      "newArchEnabled": true,
      "ios": {
         "supportsTablet": true,
         "infoPlist": {
            "LSApplicationQueriesSchemes": ["pehchan", "pehchan", "pehchan", "pehchan"],
            "ITSAppUsesNonExemptEncryption": false,
            "NSCameraUsageDescription": "This app needs camera access for Aadhaar verification in WebView.",
            "NSMicrophoneUsageDescription": "This app needs microphone access for Aadhaar verification in WebView.",
            "NSLocationWhenInUseUsageDescription": "This app needs location access for Aadhaar verification in WebView."
         },
         "bundleIdentifier": "com.anonymous.aadhaar-ovse-sop"
      },
      "android": {
         "package": "in.ongrid.lav",
         "permissions": ["CAMERA", "RECORD_AUDIO", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
         "adaptiveIcon": {
            "backgroundColor": "#E6F4FE",
            "foregroundImage": "./assets/images/android-icon-foreground.png",
            "backgroundImage": "./assets/images/android-icon-background.png",
            "monochromeImage": "./assets/images/android-icon-monochrome.png"
         },
         "edgeToEdgeEnabled": true,
         "predictiveBackGestureEnabled": false,
         "intentFilters": [
            {
               "action": "VIEW",
               "autoVerify": true,
               "data": [
                  {
                     "scheme": "aadhaarovsesop"
                  }
               ],
               "category": ["BROWSABLE", "DEFAULT"]
            }
         ]
      },
      "web": {
         "output": "static",
         "favicon": "./assets/images/favicon.png"
      },
      "plugins": [
         "expo-router",
         [
            "expo-splash-screen",
            {
               "image": "./assets/images/splash-icon.png",
               "imageWidth": 200,
               "resizeMode": "contain",
               "backgroundColor": "#ffffff",
               "dark": {
                  "backgroundColor": "#000000"
               }
            }
         ]
      ],
      "experiments": {
         "typedRoutes": true,
         "reactCompiler": true
      },
      "extra": {
         "router": {},
         "eas": {
            "projectId": "6d2fccb3-a473-4c97-b8f7-c65c86a42199"
         }
      }
   }
}
